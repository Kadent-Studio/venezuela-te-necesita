# Base de datos — Neon Postgres (Vercel Marketplace)
DATABASE_URL=            # conexión pooled (para la app)
DIRECT_URL=              # conexión directa (para migraciones de Prisma)

# Almacenamiento de fotos — Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Autenticación de coordinadores — Clerk (registro solo por invitación)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Anti-spam: secreto para el HMAC del hash de IP (rate-limit)
SECRET_KEY=
